# compact-rag 环境变量配置
# 复制此文件为 .env 并根据需要修改

# 配置文件路径
COMPACT_RAG_CONFIG=config/default.yaml

# 数据库 (覆盖 YAML 配置)
# DATABASE_URL=sqlite+aiosqlite:///data/compact-rag.db
# DATABASE_URL=mysql+asyncmy://user:pass@localhost:3306/compact_rag

# LLM API Keys
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
OLLAMA_HOST=http://localhost:11434

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 存储后端: local | minio | oss | kodo | s3
STORAGE_BACKEND=local

# MinIO (开发/测试用)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# Streamlit 管理后台密码 (留空则无需密码，仅限本地 127.0.0.1 访问)
ADMIN_PASSWORD=

# 嵌套配置覆盖 (pydantic-settings 格式)
# COMPACT_RAG_LLM__MODEL=gpt-4o
# COMPACT_RAG_LLM__TEMPERATURE=0.2
