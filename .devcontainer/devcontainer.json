{
  "name": "compact-rag Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12",
  "remoteUser": "vscode",
  "workspaceFolder": "/workspace/compact-rag",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/compact-rag,type=bind,consistency=cached",
  "mounts": [
    "source=compact-rag-venv,target=/workspace/compact-rag/.venv,type=volume",
    "source=compact-rag-data,target=/workspace/compact-rag/data,type=volume"
  ],
  "forwardPorts": [8000, 8501],
  "settings": {
    "python.defaultInterpreterPath": "/workspace/compact-rag/.venv/bin/python",
    "editor.formatOnSave": true
  },
  "extensions": [
    "ms-python.python",
    "ms-python.vscode-pylance",
    "charliermarsh.ruff",
    "ms-azuretools.vscode-docker"
  ],
  "postCreateCommand": "python -m venv .venv --copies && . .venv/bin/activate && python -m pip install --upgrade pip && pip install -e \".[dev]\"",
  "remoteEnv": {
    "COMPACT_RAG_CONFIG": "config/default.yaml"
  },
  "features": {},
  "overrideCommand": true
}
